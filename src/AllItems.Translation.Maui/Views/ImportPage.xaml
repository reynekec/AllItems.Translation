<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AllItems.Translation.Maui.Views.ImportPage"
             Title="Import">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label Text="Sync from desktop" FontSize="28" FontAttributes="Bold" />
            <Label Text="Your flashcards are exported from the desktop app to GitHub. Import here to download the latest set onto this phone."
                   Opacity="0.7" />

            <Button Text="Import latest flashcards" Command="{Binding ImportCommand}" />
            <Button Text="Check for updates" Command="{Binding CheckForUpdateCommand}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Start" />

            <Label Text="{Binding LastExportText}" Opacity="0.7" />
            <Label Text="{Binding StatusMessage}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
