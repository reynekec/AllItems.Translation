<ui:FluentWindow x:Class="AllItems.Translation.App.Views.StudySessionWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:study="clr-namespace:AllItems.Translation.Core.Study;assembly=AllItems.Translation.Core"
                 Title="Study"
                 Height="680" Width="760"
                 MinHeight="560" MinWidth="680"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <ItemsPanelTemplate x:Key="SentenceWordsPanel">
            <WrapPanel HorizontalAlignment="Center" />
        </ItemsPanelTemplate>
        <DataTemplate x:Key="SentenceWordTemplate">
            <TextBlock Text="{Binding Text}" FontSize="16" Opacity="0.85" Margin="0,0,6,0" ToolTip="{Binding Reason}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Opacity" Value="1" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </DataTemplate>
    </ui:FluentWindow.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Study" />

        <Grid Grid.Row="1" Margin="0,16,0,0">

            <!-- Setup panel -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Visibility="{Binding IsSetupVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel MaxWidth="560">
                    <TextBlock Text="Languages" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0" Opacity="0.72" TextWrapping="Wrap"
                               Text="Choose the direction you want to review before starting a study mode." />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="I know" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding SourceLanguage}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Quiz me on" Margin="0,0,0,6" />
                            <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                      SelectedItem="{Binding TargetLanguage}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Grid>

                    <Border Margin="0,18,0,0"
                            Padding="14"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                        <StackPanel>
                            <TextBlock Text="Current summary" FontWeight="SemiBold" />
                            <WrapPanel Margin="0,10,0,0">
                                <Border Margin="0,0,10,8"
                                        Padding="10,6"
                                        CornerRadius="999"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                    <TextBlock Opacity="0.82" Text="{Binding AvailableWordsText}" />
                                </Border>
                                <Border Margin="0,0,10,8"
                                        Padding="10,6"
                                        CornerRadius="999"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                    <TextBlock Opacity="0.82" Text="{Binding RetrainMissedAvailabilityText}" />
                                </Border>
                                <Border Margin="0,0,0,8"
                                        Padding="10,6"
                                        CornerRadius="999"
                                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                    <TextBlock Opacity="0.82" Text="{Binding RetrainTroubleAvailabilityText}" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Margin="0,24,0,0" Text="Study mode" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Margin="0,6,0,0" Opacity="0.72" TextWrapping="Wrap"
                               Text="Pick how you want to review this language pair right now." />

                    <ui:CardAction Margin="0,18,0,10"
                                   Command="{Binding StartSessionCommand}">
                        <StackPanel>
                            <TextBlock Text="Start session" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0" Opacity="0.72" TextWrapping="Wrap"
                                       Text="Standard spaced-repetition review using due cards first, then new cards from this language pair." />
                        </StackPanel>
                    </ui:CardAction>

                    <ui:CardAction Margin="0,0,0,10"
                                   IsEnabled="{Binding StartRetrainCurrentSessionCommand.CanExecute, Mode=OneWay}"
                                   Command="{Binding StartRetrainCurrentSessionCommand}">
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Opacity" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StartRetrainCurrentSessionCommand.CanExecute, Mode=OneWay}" Value="False">
                                            <Setter Property="Opacity" Value="0.6" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Retrain missed" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0" Opacity="0.72" TextWrapping="Wrap"
                                       Text="Go back over cards you marked Again in your latest study session." />
                            <TextBlock Margin="0,8,0,0" Opacity="0.65" FontSize="12"
                                       Text="{Binding RetrainMissedAvailabilityText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RetrainMissedCount}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0" Opacity="0.75" FontSize="12"
                                       Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                       Text="{Binding RetrainMissedEmptyText}"
                                       Visibility="{Binding RetrainMissedEmptyText, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                        </StackPanel>
                    </ui:CardAction>

                    <ui:CardAction IsEnabled="{Binding StartLeechSessionCommand.CanExecute, Mode=OneWay}"
                                   Command="{Binding StartLeechSessionCommand}">
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Opacity" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StartLeechSessionCommand.CanExecute, Mode=OneWay}" Value="False">
                                            <Setter Property="Opacity" Value="0.6" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Retrain trouble" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Margin="0,4,0,0" Opacity="0.72" TextWrapping="Wrap"
                                       Text="Focus on persistent trouble words that have repeatedly come back wrong." />
                            <TextBlock Margin="0,8,0,0" Opacity="0.65" FontSize="12"
                                       Text="{Binding RetrainTroubleAvailabilityText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RetrainTroubleCount}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0" Opacity="0.75" FontSize="12"
                                       Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                       Text="{Binding RetrainTroubleEmptyText}"
                                       Visibility="{Binding RetrainTroubleEmptyText, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                        </StackPanel>
                    </ui:CardAction>

                    <Border Margin="0,18,0,0"
                            Padding="14"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            Visibility="{Binding StatusMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Session info" FontWeight="SemiBold" />
                            <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Opacity="0.8"
                                       Text="{Binding StatusMessage}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Session complete panel -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsSessionComplete, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="Session complete!" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Margin="0,8,0,0" HorizontalAlignment="Center">
                    <Run Text="Reviewed " /><Run Text="{Binding ReviewedCount, Mode=OneWay}" /><Run Text=" card(s)." />
                </TextBlock>
                <ui:Button Content="Study Again" Appearance="Primary" Margin="0,20,0,0" HorizontalAlignment="Center"
                           Command="{Binding RestartCommand}" />
            </StackPanel>

            <!-- Active card panel -->
            <Grid Visibility="{Binding IsSessionActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding ProgressText}" Opacity="0.6" />
                    <TextBlock Margin="8,0,0,0" Text="{Binding ActiveProgressDetail}" Opacity="0.6" />
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding FrontText}" FontSize="32" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="Wrap" />

                    <!-- Source-language sentence on the front: it's in the prompt's language, so it never leaks the answer. -->
                    <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding SentenceWords}"
                                  ItemsPanel="{StaticResource SentenceWordsPanel}"
                                  ItemTemplate="{StaticResource SentenceWordTemplate}"
                                  Visibility="{Binding ExampleSentence, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />

                    <!-- Answer and its destination-language sentence stay hidden until the card is flipped. -->
                    <StackPanel Visibility="{Binding IsAnswerShown, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Margin="0,20,0,0" FontSize="26" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   Text="{Binding BackText}" />

                        <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding BackSentenceWords}"
                                      ItemsPanel="{StaticResource SentenceWordsPanel}"
                                      ItemTemplate="{StaticResource SentenceWordTemplate}"
                                      Visibility="{Binding BackExampleSentence, Converter={StaticResource NullOrEmptyToVisibilityConverter}}" />
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="2" Margin="0,20,0,0">
                    <ui:Button Content="Show Answer" Appearance="Primary" HorizontalAlignment="Center"
                               Command="{Binding ShowAnswerCommand}"
                               Visibility="{Binding IsAnswerShown, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Visibility="{Binding IsAnswerShown, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ui:Button Content="Again" Appearance="Danger" Margin="0,0,8,0"
                                   Command="{Binding GradeCommand}" CommandParameter="{x:Static study:ReviewGrade.Again}" />
                        <ui:Button Content="Good" Appearance="Primary" Margin="0,0,8,0"
                                   Command="{Binding GradeCommand}" CommandParameter="{x:Static study:ReviewGrade.Good}" />
                        <ui:Button Content="Easy" Appearance="Success"
                                   Command="{Binding GradeCommand}" CommandParameter="{x:Static study:ReviewGrade.Easy}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
