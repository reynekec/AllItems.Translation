<ui:FluentWindow x:Class="AllItems.Translation.App.Views.DictionaryManagerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Dictionary Manager"
                 Height="600" Width="800"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Dictionary Manager" />

        <DataGrid Grid.Row="1" Margin="0,12,0,0"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Source language" Binding="{Binding SourceLanguage, Mode=OneWay}" IsReadOnly="True" Width="120" />
                <DataGridTextColumn Header="Word" Binding="{Binding SourceWord, Mode=OneWay}" IsReadOnly="True" Width="150" />
                <DataGridTextColumn Header="Target language" Binding="{Binding TargetLanguage, Mode=OneWay}" IsReadOnly="True" Width="120" />
                <DataGridTextColumn Header="Meaning" Binding="{Binding TargetText, UpdateSourceTrigger=LostFocus}" Width="*" />
                <DataGridCheckBoxColumn Header="Preferred" Binding="{Binding IsPreferred, Mode=OneWay}" IsReadOnly="True" Width="80" />
                <DataGridTemplateColumn Header="" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button Content="Save" Appearance="Secondary" Margin="0,0,4,0"
                                           Command="{Binding DataContext.SaveRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           CommandParameter="{Binding}" />
                                <ui:Button Content="Delete" Appearance="Danger"
                                           Command="{Binding DataContext.DeleteRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                           CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</ui:FluentWindow>
