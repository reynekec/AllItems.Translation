<ui:FluentWindow x:Class="AllItems.Translation.App.Views.StartWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
 Title="AllItems.Translation" Width="560" Height="480" MinWidth="480" MinHeight="420" WindowStartupLocation="CenterScreen" ExtendsContentIntoTitleBar="True" WindowBackdropType="Mica">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <!-- Title Bar -->
    <ui:TitleBar Grid.Row="0" Height="32" MinHeight="32" Title="AllItems.Translation" />
    <!-- Main Content -->
    <Grid Grid.Row="1" Margin="0,16,0,0">
      <StackPanel VerticalAlignment="Center">
        <ui:CardAction Margin="0,0,0,12" Click="OnTranslationsClick">
          <StackPanel>
            <TextBlock Text="Translations" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Margin="0,4,0,0" Opacity="0.7" TextWrapping="Wrap" Text="Type a sentence and see it reassembled word-by-word in the other two languages."/>
          </StackPanel>
        </ui:CardAction>
        <ui:CardAction Margin="0,0,0,12" Click="OnFlashcardsClick">
          <StackPanel>
            <TextBlock Text="Flashcards" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Margin="0,4,0,0" Opacity="0.7" TextWrapping="Wrap" Text="Review your dictionary with spaced-repetition flashcards."/>
          </StackPanel>
        </ui:CardAction>
        <ui:CardAction Click="OnTrainingClick">
          <StackPanel>
            <TextBlock Text="Training" FontSize="18" FontWeight="SemiBold"/>
            <TextBlock Margin="0,4,0,0" Opacity="0.7" TextWrapping="Wrap" Text="More exercises - coming soon."/>
          </StackPanel>
        </ui:CardAction>
        <ui:CardAction Margin="0,12,0,0" Click="OnSettingsClick"
                       Background="#2F6B5F" Foreground="White" BorderBrush="#3B8678" BorderThickness="1">
          <StackPanel>
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="Settings24" FontSize="18" Margin="0,0,8,0" Foreground="White" />
              <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
            </StackPanel>
            <TextBlock Margin="0,4,0,0" Opacity="0.8" TextWrapping="Wrap" Foreground="White" Text="Manage Google Cloud credentials and import vocabulary."/>
          </StackPanel>
        </ui:CardAction>
      </StackPanel>
    </Grid>
  </Grid>
</ui:FluentWindow>