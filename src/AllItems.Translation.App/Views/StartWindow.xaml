<ui:FluentWindow x:Class="AllItems.Translation.App.Views.StartWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="AllItems.Translation"
                 Height="480" Width="560"
                 MinHeight="420" MinWidth="480"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="AllItems.Translation">
            <ui:TitleBar.TrailingContent>
                <ui:Button Appearance="Secondary" ToolTip="Settings" Click="OnSettingsClick"
                           Icon="{ui:SymbolIcon Settings24}" />
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,16,0,0">
            <ui:CardAction Margin="0,0,0,12" Click="OnTranslationsClick">
                <StackPanel>
                    <TextBlock Text="Translations" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0" Opacity="0.7" TextWrapping="Wrap"
                               Text="Type a sentence and see it reassembled word-by-word in the other two languages." />
                </StackPanel>
            </ui:CardAction>

            <ui:CardAction Margin="0,0,0,12" Click="OnFlashcardsClick">
                <StackPanel>
                    <TextBlock Text="Flashcards" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0" Opacity="0.7" TextWrapping="Wrap"
                               Text="Review your dictionary with spaced-repetition flashcards." />
                </StackPanel>
            </ui:CardAction>

            <ui:CardAction Click="OnTrainingClick">
                <StackPanel>
                    <TextBlock Text="Training" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Margin="0,4,0,0" Opacity="0.7" TextWrapping="Wrap"
                               Text="More exercises - coming soon." />
                </StackPanel>
            </ui:CardAction>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
