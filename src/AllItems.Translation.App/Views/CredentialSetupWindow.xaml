<ui:FluentWindow x:Class="AllItems.Translation.App.Views.CredentialSetupWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Connect Google Cloud Translation"
                 Height="640" Width="620"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Connect Google Cloud Translation" ShowMaximize="False" ShowMinimize="False" />

        <TextBlock Grid.Row="1" Margin="0,12,0,8" TextWrapping="Wrap"
                   Text="Paste the full contents of your Google Cloud service-account JSON key. It is saved locally under %LOCALAPPDATA%\AllItems.Translation\credentials and is never stored anywhere else." />

        <ui:TextBox Grid.Row="2"
                    Text="{Binding JsonInput, UpdateSourceTrigger=PropertyChanged}"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    FontFamily="Consolas"
                    PlaceholderText="{}{ &quot;type&quot;: &quot;service_account&quot;, ... }" />

        <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="IndianRed" TextWrapping="Wrap"
                   Text="{Binding ErrorMessage}"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <ui:Button Content="Save and Continue" Appearance="Primary" Command="{Binding SaveCommand}" />
        </StackPanel>

        <Border Grid.Row="5" Margin="0,20,0,0" BorderThickness="0,1,0,0" BorderBrush="Gray" Padding="0,16,0,0">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Vocabulary" />
                <TextBlock Margin="0,4,0,8" TextWrapping="Wrap" Opacity="0.8"
                           Text="Words normally import level-by-level as you complete Training. Use this to load every CEFR level's vocabulary into the Dictionary right away." />
                <StackPanel Orientation="Horizontal">
                    <ui:Button Content="Import all vocabulary"
                               Appearance="Secondary"
                               Command="{Binding ImportAllVocabularyCommand}" />
                    <ui:ProgressRing Width="16" Height="16" Margin="12,0,0,0"
                                     IsIndeterminate="True"
                                     Visibility="{Binding IsImportingVocabulary, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
                <TextBlock Margin="0,8,0,0" TextWrapping="Wrap"
                           Text="{Binding VocabularyImportStatus}"
                           Visibility="{Binding VocabularyImportStatus, Converter={StaticResource NullOrEmptyToVisibilityConverter}, FallbackValue=Collapsed}" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
